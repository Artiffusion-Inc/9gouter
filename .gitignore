/build
.idea/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.bin/*
data/
logs/*
source/*
.cursor/*
docs/*
!docs/ARCHITECTURE.md
test/*
open-sse/test/*
RM.vn.md
RM.md
cursor/*
PUBLIC.md
Thanks.md
PUBLIC.en.md
PR/*
package-lock.json


# Go build artifacts
/9gouter
*.test

#Ignore vscode AI rules
.github/instructions/codacy.instructions.md
README1.md
deploy*.sh
ecosystem.config.*

scripts/agSniffer/*
gitbooks/*
gitbook/README.md

# Refactor backup reference (do not bundle/lint)
open-sse.old/
.graphifyignore
graphify-out/*

# Local-only working dirs (notes, vendored repos, scripts, skills)
.claude/
.docs/
.repo/
.script/
.codegraph/
.PR/
.next-analyze/*

# Go-embedded dashboard static export (built by scripts/build-dashboard.sh).
# Keep only the placeholder index.html for clean-clone `go build` embed compilation;
# the real export is regenerated on build and not tracked.
internal/adapter/transport/http/dashboard_assets/*
!internal/adapter/transport/http/dashboard_assets/.gitkeep

# Shadow-diff runtime artifacts (tools/shadowdiff/main.go is the tracked source).
# mismatches.jsonl + traffic/ are generated by a shadow-diff run; the root
# ./shadowdiff file is the compiled binary.
/shadowdiff
tools/shadowdiff/mismatches.jsonl
tools/shadowdiff/traffic/

# e2e import scratch (never commit)
/tools/import-backup/
